# Server
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# Database (PostgreSQL) - use credenciais do docker-compose
DATABASE_URL=postgresql://USER_DATABASE:USER_PASSWORD@localhost:5432/DATABASE_NAME?schema=public

# JWT (HS256) — use pelo menos 32 caracteres em produção
JWT_SECRET=change-me-to-a-secret-with-at-least-32-chars
JWT_EXPIRES_IN=7d

# CORS — obrigatório: origens permitidas (vírgula), sem wildcard
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Serviço de IA (projeto separado)
AI_SERVICE_URL=http://localhost:8000

# Evolution API
EVOLUTION_API_URL=
EVOLUTION_API_KEY=
