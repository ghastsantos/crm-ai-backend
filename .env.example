# Server
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# Database (PostgreSQL) - use credenciais do docker-compose
DATABASE_URL=postgresql://crm:crm@localhost:5432/crm_ai?schema=public

# CORS - origens permitidas separadas por vírgula
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Serviço de IA (projeto separado)
AI_SERVICE_URL=http://localhost:8000

# Evolution API
EVOLUTION_API_URL=
EVOLUTION_API_KEY=
