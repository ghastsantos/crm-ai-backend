# Server
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# --- Produção pública (exemplo; ajustar antes do deploy) ---
# NODE_ENV=production
# API_DOCS_ENABLED=false
# AUTH_TOKEN_IN_BODY=false
# AUTH_ENFORCE_ORIGIN_ON_MUTATIONS=true

# Database (PostgreSQL) — credenciais por defeito no docker-compose.yml
# O compose publica Postgres em 127.0.0.1:5433 (dentro do container continua 5432).
DATABASE_URL=postgresql://crm:crm@127.0.0.1:5433/crm_ai?schema=public

# JWT (HS256)
# JWT_SECRET é a chave fixa usada para assinar/verificar tokens, não um JWT pronto.
# Gere uma string aleatória por ambiente e mantenha em segredo.
# Ex.: node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
JWT_SECRET=change-me-to-a-random-secret-with-at-least-32-chars
JWT_EXPIRES_IN=7d

# CORS — em produção use origens exatas; em desenvolvimento portas locais extras são aceitas
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Reverse proxy: saltos confiáveis para X-Forwarded-For (0 = desligado). Ex.: 1 atrás de Nginx.
TRUST_PROXY_HOPS=0

# Documentação OpenAPI em /api-docs (em produção use false)
API_DOCS_ENABLED=true

# WhatsApp real via Baileys/WhatsApp Web
WHATSAPP_PROVIDER=baileys
WHATSAPP_INSTANCE_NAME=crm-global
WHATSAPP_AUTH_DIR=.data/baileys-auth
WHATSAPP_AUTO_START=true
# Opcional: lista de telefones que o bot pode atender automaticamente.
# Vazio = atende qualquer conversa privada recebida. Ex.: 5541999998888,5541888877777
WHATSAPP_ALLOWED_NUMBERS=
# IA do chatbot
AI_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite

# Cookie httpOnly com JWT (recomendado). Token no JSON: AUTH_TOKEN_IN_BODY=true para Postman/CLI.
AUTH_HTTPONLY_COOKIE_ENABLED=true
AUTH_COOKIE_NAME=crm_access_token
AUTH_TOKEN_IN_BODY=true
AUTH_COOKIE_SAME_SITE=lax
# Produção com SPA conhecida: true exige header Origin em POST/PUT/PATCH/DELETE sob /api/v1
AUTH_ENFORCE_ORIGIN_ON_MUTATIONS=false
