generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum OrganizationRole {
  OWNER
  MEMBER
}

enum PipelineLogAction {
  DEAL_CREATED
  DEAL_MOVED
  DEAL_UPDATED
  DEAL_ARCHIVED
  DEAL_DELETED
  OWNER_CHANGED
  COLUMN_CREATED
  COLUMN_UPDATED
  COLUMN_DELETED
}

model HealthCheck {
  id        String   @id @default(cuid())
  checkedAt DateTime @default(now())
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  memberships  OrganizationMember[]
  pipelineLogs PipelineLog[]
}

model Organization {
  id        String   @id @default(cuid())
  name      String
  niche     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members         OrganizationMember[]
  contacts        Contact[]
  deals           Deal[]
  pipelineColumns PipelineColumn[]
  pipelineLogs    PipelineLog[]
}

model OrganizationMember {
  id             String           @id @default(cuid())
  role           OrganizationRole @default(MEMBER)
  createdAt      DateTime         @default(now())
  userId         String
  organizationId String

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
  @@index([organizationId])
}

model PipelineColumn {
  id             String   @id @default(cuid())
  organizationId String
  title          String
  position       Int
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  deals        Deal[]

  logsFrom PipelineLog[] @relation("PipelineLogFromColumn")
  logsTo   PipelineLog[] @relation("PipelineLogToColumn")

  @@unique([organizationId, position])
  @@index([organizationId])
}

model Contact {
  id             String   @id @default(cuid())
  name           String
  phone          String
  email          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  organizationId String

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  deals        Deal[]

  @@index([organizationId, phone])
}

model Deal {
  id               String   @id @default(cuid())
  title            String
  value            Decimal? @db.Decimal(14, 2)
  companyName      String?
  contactName      String?
  email            String?
  phone            String?
  notes            String?
  position         Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  organizationId   String
  contactId        String?
  pipelineColumnId String

  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  contact        Contact?       @relation(fields: [contactId], references: [id], onDelete: SetNull)
  pipelineColumn PipelineColumn @relation(fields: [pipelineColumnId], references: [id], onDelete: Restrict)

  pipelineLogs PipelineLog[]

  @@index([organizationId])
  @@index([pipelineColumnId])
  @@index([pipelineColumnId, position])
}

model PipelineLog {
  id             String            @id @default(cuid())
  organizationId String
  userId         String?
  dealId         String?
  action         PipelineLogAction
  description    String
  fromColumnId   String?
  toColumnId     String?
  fromColumnName String?
  toColumnName   String?
  previousValue  String?
  newValue       String?
  metadata       Json?
  createdAt      DateTime          @default(now())

  organization Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User?           @relation(fields: [userId], references: [id], onDelete: SetNull)
  deal         Deal?           @relation(fields: [dealId], references: [id], onDelete: SetNull)
  fromColumn   PipelineColumn? @relation("PipelineLogFromColumn", fields: [fromColumnId], references: [id], onDelete: SetNull)
  toColumn     PipelineColumn? @relation("PipelineLogToColumn", fields: [toColumnId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([userId])
  @@index([dealId])
  @@index([action])
  @@index([createdAt])
  @@index([organizationId, createdAt])
}